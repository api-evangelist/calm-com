  "info": {
    "_postman_id": "e2caca45-ecf7-4224-b8c6-d7d8d5bde0ac",
    "name": "Calm Partner API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Partner API for Calm Business and Calm Health partners. Provisions and manages Calm subscriptions for partner end users via OAuth 2.0 client credentials. Three operations cover the full subscription lifecycle: authorize the partner service, link a partner user to a Calm subscription, and cancel an existing subscription. Credentials are issued by Calm's B2B Engineering Team.\n\nContact Support:\n Name: Calm B2B Engineering Team",
      "type": "text/plain"
    }
  }
